server {
    listen 80;
    server_name __POLYDATA_SERVER_NAME__ _;

    root /var/www/polydata;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Agent endpoints call paid LLM APIs. Keep them out of the public web
    # surface; use the loopback API or an authenticated private tunnel instead.
    location ^~ /wm-api/agent/ {
        return 403;
    }

    location /wm-api/ {
        proxy_pass __POLYDATA_API_UPSTREAM__/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 10s;
        proxy_read_timeout 60s;
        proxy_send_timeout 60s;
    }
}
