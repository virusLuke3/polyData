# Shared runtime environment for user-level systemd-managed polyData services.
# Copy to ~/.config/polydata/polydata.env and fill in real values.

POLYMARKET_DB_BACKEND=mysql
POLYMARKET_MYSQL_HOST=127.0.0.1
POLYMARKET_MYSQL_PORT=43306
POLYMARKET_MYSQL_USER=poly_user
POLYMARKET_MYSQL_PASSWORD=REPLACE_ME
POLYMARKET_MYSQL_DATABASE=poly_data
POLYMARKET_MYSQL_CHARSET=utf8mb4

# Prefer POLYMARKET_RPC_URL; NODE_URL is also supported by the codebase.
POLYMARKET_RPC_URL=

# Optional Python interpreter override, useful for conda or venv installs.
POLYDATA_PYTHON_BIN=python3

POLYDATA_API_HOST=0.0.0.0
POLYDATA_API_PORT=18500
POLYDATA_REDIS_URL=redis://127.0.0.1:6379/0
POLYDATA_REDIS_PREFIX=polydata:
POLYDATA_CLOB_API_BASE=https://clob.polymarket.com
POLYDATA_CRYPTO_FUNDING_WATCH_API_URL=
POLYDATA_CRYPTO_FUNDING_WATCH_BYBIT_API_URL=
POLYDATA_CRYPTO_FUNDING_WATCH_API_KEY=
POLYDATA_CRYPTO_FUNDING_WATCH_BYBIT_API_KEY=
POLYDATA_CRYPTO_FUNDING_WATCH_SOURCE_URL=
POLYDATA_CRYPTO_FUNDING_WATCH_TTL_SECONDS=15
POLYDATA_CRYPTO_FUNDING_WATCH_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT,ADAUSDT,AVAXUSDT,LINKUSDT,LTCUSDT,DOTUSDT,TRXUSDT,BCHUSDT,SUIUSDT,TONUSDT,NEARUSDT,APTUSDT,ETCUSDT
POLYDATA_GEO_SHOCK_OFAC_SDN_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/SDN.XML
POLYDATA_GEO_SHOCK_OFAC_CONSOLIDATED_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/CONSOLIDATED.XML
POLYDATA_GEO_SHOCK_FEDERAL_REGISTER_API_URL=https://www.federalregister.gov/api/v1/documents.json
POLYDATA_GEO_SHOCK_CONFLICT_API_URL=
POLYDATA_GEO_SHOCK_GDELT_DOC_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
POLYDATA_GEO_SHOCK_ACLED_TOKEN_URL=https://acleddata.com/oauth/token
POLYDATA_GEO_SHOCK_ACLED_API_URL=https://acleddata.com/api/acled/read
POLYDATA_GEO_SHOCK_ACLED_EMAIL=
POLYDATA_GEO_SHOCK_ACLED_PASSWORD=
ACLED_USERNAME=
ACLED_PASSWORD=
POLYDATA_GEO_SHOCK_SOURCE_URL=https://ofac.treasury.gov/sanctions-list-service
POLYDATA_GEO_SHOCK_TTL_SECONDS=900
POLYDATA_GEO_SHOCK_WATCH_INTERVAL_SECONDS=300
POLYDATA_JIN10_WATCH_INTERVAL_SECONDS=60
POLYDATA_JIN10_LIMIT=24
POLYDATA_JIN10_SEED_TTL_SECONDS=180
POLYDATA_F1_WATCH_INTERVAL_SECONDS=180
POLYDATA_F1_LIMIT=10
POLYDATA_F1_SEED_TTL_SECONDS=540
POLYDATA_NBA_WATCH_INTERVAL_SECONDS=60
POLYDATA_NBA_SCOREBOARD_LIMIT=10
POLYDATA_NBA_INTEL_LIMIT=12
POLYDATA_NBA_PREDICTOR_LIMIT=8
POLYDATA_NBA_SEED_TTL_SECONDS=180
POLYDATA_MARKET_GROUP_WATCH_INTERVAL_SECONDS=60
POLYDATA_MARKET_GROUP_SEED_TTL_SECONDS=180
POLYDATA_CRYPTO_FUNDING_WATCH_INTERVAL_SECONDS=30
POLYDATA_CRYPTO_FUNDING_LIMIT=18
POLYDATA_CRYPTO_FUNDING_SEED_TTL_SECONDS=90
POLYDATA_INFLATION_NOWCAST_WATCH_INTERVAL_SECONDS=1800
POLYDATA_INFLATION_NOWCAST_SEED_TTL_SECONDS=5400
POLYDATA_SIGNAL_WATCH_INTERVAL_SECONDS=45
POLYDATA_SIGNAL_SEED_TTL_SECONDS=135
POLYDATA_ALPHA_SIGNAL_LIMIT=8
POLYDATA_WHALE_TRADES_LIMIT=14
POLYDATA_SUSPICIOUS_TRADES_LIMIT=12
POLYDATA_BOOTSTRAP_SEED_INTERVAL_SECONDS=60
POLYDATA_BOOTSTRAP_SEED_TTL_SECONDS=180

# Optional runtime overrides.
POLYDATA_ALLOWED_ORIGINS=
POLYDATA_SNAPSHOT_SQLITE_PATH=/__POLYDATA_REPO_ROOT__/data/panel_snapshots.sqlite3

# Optional outbound proxy for environments where direct internet access is blocked.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
