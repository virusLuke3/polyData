[Unit]
Description=polyData API service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/__POLYDATA_REPO_ROOT__
EnvironmentFile=%h/.config/polydata/polydata.env
ExecStart=/bin/bash -lc 'exec "${POLYDATA_PYTHON_BIN:-python3}" scripts/api_server.py --backend postgres --skip-init-schema --host "${POLYDATA_API_HOST:-127.0.0.1}" --port "${POLYDATA_API_PORT:-18500}"'
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=polydata.target
