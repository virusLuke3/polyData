# POLYDATA_GEO_SHOCK_UCDP_ACCESS_TOKEN=<your_ucdp_api_token>
# UCDP_API_TOKEN=<optional_alias_for_ucdp_api_token>
# UCDP_API_Token=<legacy_optional_alias_for_ucdp_api_token>
# UCDP_ACCESS_TOKEN=<worldmonitor_alias_for_ucdp_api_token>
# UC_DP_KEY=<legacy_worldmonitor_alias_for_ucdp_api_token>
