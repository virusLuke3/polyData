# POLYDATA_GEO_SHOCK_ACLED_API_URL=https://acleddata.com/api/acled/read
# POLYDATA_GEO_SHOCK_ACLED_EMAIL=<your_acled_account_email>
# POLYDATA_GEO_SHOCK_ACLED_PASSWORD=<your_acled_account_password>
# ACLED_USERNAME=<optional_alias_for_acled_email>
# ACLED_PASSWORD=<optional_alias_for_acled_password>
# POLYDATA_GEO_SHOCK_SOURCE_URL=https://ofac.treasury.gov/sanctions-list-service
# POLYDATA_GEO_SHOCK_TTL_SECONDS=900
# POLYDATA_GEO_SHOCK_WATCH_INTERVAL_SECONDS=300
# POLYDATA_F1_BWENEWS_RSS_URL=<your_f1_or_sports_runtime_rss_url>
# POLYDATA_F1_BWENEWS_SOURCE_URL=<your_f1_or_sports_runtime_source_url>
# POLYDATA_F1_WATCH_INTERVAL_SECONDS=180
# POLYDATA_F1_LIMIT=10
# POLYDATA_F1_SEED_TTL_SECONDS=540
# POLYDATA_NBA_WATCH_INTERVAL_SECONDS=60
# POLYDATA_NBA_SCOREBOARD_LIMIT=10
# POLYDATA_NBA_INTEL_LIMIT=12
# POLYDATA_NBA_PREDICTOR_LIMIT=8
# POLYDATA_NBA_SEED_TTL_SECONDS=180

# ============================================================
# AI / Agent
# ============================================================

# API_KEY=<your_openai_compatible_api_key>
# TAVILY_API_KEY=<your_tavily_api_key>
# POLYDATA_AGENT_ENV_PATH=<optional_private_agent_env_file_path>
# POLYDATA_AGENT_API_BASE=https://gpt-api.hkust-gz.edu.cn/v1/chat/completions
# POLYDATA_AGENT_MODEL=gpt-5.3-chat
# POLYDATA_AGENT_TIMEOUT_SECONDS=45
# POLYDATA_AGENT_SSL_VERIFY=false
# POLYDATA_AGENT_GATEWAY_BASE_URL=http://127.0.0.1:18700
# POLYDATA_AGENT_GATEWAY_URL=http://127.0.0.1:18700/agent/market-insights
# POLYDATA_AGENT_GATEWAY_TOKEN=<shared_secret_for_gcp_to_agent_gateway>
# POLYDATA_AGENT_GATEWAY_TIMEOUT_SECONDS=55
# POLYDATA_AGENT_CACHE_TTL_SECONDS=300
# POLYDATA_AGENT_LOCAL_ONLY=true
# POLYDATA_AGENT_RATE_LIMIT_PER_MINUTE=6
# POLYDATA_AGENT_DAILY_LIVE_CALL_LIMIT=4
# POLYDATA_AGENT_BUDGET_STATE_PATH=~/.cache/polydata/agent-budget.json
# POLYDATA_AGENT_SEED_ENABLED=false
# POLYDATA_AGENT_MARKET_WIDE_TIMER_LENS=overview
# POLYDATA_AGENT_MARKET_WIDE_SNAPSHOT_TTL_SECONDS=43200
# POLYDATA_AGENT_MARKET_WIDE_MIN_LIVE_INTERVAL_SECONDS=43200
# POLYDATA_AGENT_SERVER_TOKEN=<optional_server_to_server_secret>
# POLYDATA_AGENT_GATEWAY_HOST=127.0.0.1
# POLYDATA_AGENT_GATEWAY_PORT=18700
# POLYDATA_AGENT_GATEWAY_REMOTE=<ssh_user>@<agent_gateway_host>
# POLYDATA_AGENT_GATEWAY_REMOTE_PORT=18700
# POLYDATA_TAVILY_SEARCH_URL=https://api.tavily.com/search
# POLYDATA_TAVILY_TIMEOUT_SECONDS=10
# POLYDATA_TAVILY_MAX_RESULTS=3

# ============================================================
# Database / PostgreSQL
# ============================================================

# POLYDATA_POSTGRES_HOST=<your_postgres_host>
