# ============================================================
# 环境变量示例（可提交到 GitHub）
# 使用方式：复制为 .env 后填入真实值，.env 不要提交
# 注意：本文件只保留占位符，不放真实地址、端口、URL、密钥
# ============================================================

# ============================================================
# Polygon / Indexer
# ============================================================

# POLYMARKET_RPC_URL=<your_polygon_rpc_url>
# NODE_URL=<your_polygon_rpc_url>
# POLYMARKET_DB=<your_indexer_db_path>
# POLYMARKET_DB_BACKEND=<your_db_backend>

# ============================================================
# Database / MySQL
# ============================================================

# POLYMARKET_MYSQL_HOST=<your_mysql_host>
# POLYMARKET_MYSQL_PORT=<your_mysql_port>
# POLYMARKET_MYSQL_USER=<your_mysql_user>
# POLYMARKET_MYSQL_PASSWORD=<your_mysql_password>
# POLYMARKET_MYSQL_DATABASE=<your_mysql_database>
# POLYMARKET_MYSQL_CHARSET=<your_mysql_charset>

# ============================================================
# API Server / Frontend
# ============================================================

# POLYDATA_API_HOST=<your_api_host>
# POLYDATA_API_PORT=<your_api_port>
# POLYDATA_ALLOWED_ORIGINS=<comma_separated_allowed_origins>
# VITE_POLYDATA_API_BASE_URL=<your_frontend_api_base_url>
# POLYDATA_PUBLIC_WEB_URL=<your_frontend_web_url>

# ============================================================
# Redis / Snapshot
# ============================================================

# POLYDATA_REDIS_URL=<your_redis_url>
# POLYDATA_REDIS_PREFIX=<your_redis_prefix>
# POLYDATA_SNAPSHOT_SQLITE_PATH=<your_snapshot_sqlite_path>
# POLYDATA_SNAPSHOT_PREWARM=<enable_or_disable_snapshot_prewarm>

# ============================================================
# API 缓存 / Runtime TTL
# ============================================================

# POLYDATA_DASHBOARD_CACHE_TTL_SECONDS=<dashboard_cache_ttl_seconds>
# POLYDATA_MARKETS_CACHE_TTL_SECONDS=<markets_cache_ttl_seconds>
# POLYDATA_BOOTSTRAP_CACHE_TTL_SECONDS=<bootstrap_cache_ttl_seconds>
# POLYDATA_BOOTSTRAP_COMPONENT_TTL_SECONDS=<bootstrap_component_ttl_seconds>
# POLYDATA_DASHBOARD_TRADE_WINDOW=<dashboard_trade_window>
# POLYDATA_ADDRESS_CACHE_TTL_SECONDS=<address_cache_ttl_seconds>
# POLYDATA_CLOB_TIMEOUT_SECONDS=<clob_timeout_seconds>
# POLYDATA_CLOB_PRICE_CACHE_TTL_SECONDS=<clob_price_cache_ttl_seconds>
# POLYDATA_FINANCE_RUNTIME_TTL_SECONDS=<finance_runtime_ttl_seconds>
# POLYDATA_FINANCE_DEFILLAMA_YIELDS_URL=https://yields.llama.fi/pools
# POLYDATA_FINANCE_ALTERNATIVE_FNG_URL=https://api.alternative.me/fng/
# POLYDATA_FINANCE_GOOGLE_NEWS_RSS_URL=https://news.google.com/rss/search
# POLYDATA_FINANCE_YAHOO_CHART_URL_TEMPLATE=https://query1.finance.yahoo.com/v8/finance/chart/{symbol}
# POLYDATA_FINANCE_FRED_CSV_URL_TEMPLATE=https://fred.stlouisfed.org/graph/fredgraph.csv?id={series_id}
# POLYDATA_FINANCE_BARCHART_QUOTE_URL_TEMPLATE=https://www.barchart.com/stocks/quotes/{symbol}
# POLYDATA_FINANCE_CNN_FNG_URL=https://production.dataviz.cnn.io/index/fearandgreed/current
# POLYDATA_FINANCE_CNN_FNG_REFERER_URL=https://www.cnn.com/markets/fear-and-greed
# POLYDATA_FINANCE_AAII_SENTIMENT_URL=https://www.aaii.com/sentimentsurvey/sent_results
# POLYDATA_FINANCE_BROKER_RESEARCH_FEED_URLS=<comma_separated_original_research_json_or_rss_urls>
# POLYDATA_FINANCE_BROKER_RESEARCH_NEWS_FALLBACK=false
# POLYDATA_FINANCE_BROKER_RESEARCH_EDISON_URL=https://www.edisongroup.com/equity-research/
# POLYDATA_FINANCE_BROKER_RESEARCH_ZACKS_URL=https://scr.zacks.com/news/default.aspx
# POLYDATA_FINANCE_BROKER_RESEARCH_WATER_TOWER_URL=https://www.watertowerresearch.com/research
# POLYDATA_FINANCE_HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
# POLYDATA_FINANCE_OKX_MARKET_TICKER_URL=https://www.okx.com/api/v5/market/ticker
# POLYDATA_FINANCE_DEFILLAMA_STABLECOINS_URL=https://stablecoins.llama.fi/stablecoins
# POLYDATA_FINANCE_CFTC_LEGACY_COT_URL=https://publicreporting.cftc.gov/resource/6dca-aqww.json
# POLYDATA_SPORTS_RUNTIME_TTL_SECONDS=<sports_runtime_ttl_seconds>
# POLYDATA_SIGNAL_RUNTIME_TTL_SECONDS=<signal_runtime_ttl_seconds>

