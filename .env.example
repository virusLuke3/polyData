# ============================================================
# 环境变量示例（可提交到 GitHub）
# 使用方式：复制为 .env 后填入真实值，.env 不要提交
# ============================================================

# Polygon RPC URL（二选一即可，优先 POLYMARKET_RPC_URL）
# 示例：Chainstack 带 key 的 URL
# POLYMARKET_RPC_URL=https://polygon-mainnet.core.chainstack.com/YOUR_CHAINSTACK_KEY
# 或使用 NODE_URL（与 chainStackNode 等命名一致）
# NODE_URL=https://polygon-mainnet.core.chainstack.com/YOUR_CHAINSTACK_KEY

# 公开节点（不填上述变量时，脚本默认使用 polygon-rpc.com）
# POLYMARKET_RPC_URL=
# NODE_URL=

# 可选：索引器数据库路径（默认 database/polymarket_indexer.db）
# POLYMARKET_DB=database/polymarket_indexer.db
