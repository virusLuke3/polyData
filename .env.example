# POLYMARKET_PostgreSQL_PASSWORD=<your_postgres_password>
# POLYDATA_POSTGRES_DATABASE=<your_postgres_database>
# POLYDATA_POSTGRES_SEARCH_PATH=<your_postgres_search_path>

