# ============================================================
# 环境变量示例（可提交到 GitHub）
# 使用方式：复制为 .env 后填入真实值，.env 不要提交
# 注意：本文件只保留占位符，不放真实地址、端口、URL、密钥
# ============================================================

# ============================================================
# Polygon / Indexer
# ============================================================

# POLYMARKET_RPC_URL=<your_polygon_rpc_url>
# NODE_URL=<your_polygon_rpc_url>
# POLYMARKET_DB=<your_indexer_db_path>
# POLYMARKET_DB_BACKEND=<your_db_backend>

# ============================================================
# Database / MySQL
# ============================================================

# POLYMARKET_MYSQL_HOST=<your_mysql_host>
# POLYMARKET_MYSQL_PORT=<your_mysql_port>
# POLYMARKET_MYSQL_USER=<your_mysql_user>
# POLYMARKET_MYSQL_PASSWORD=<your_mysql_password>
# POLYMARKET_MYSQL_DATABASE=<your_mysql_database>
# POLYMARKET_MYSQL_CHARSET=<your_mysql_charset>

# ============================================================
# API Server / Frontend
# ============================================================

# POLYDATA_API_HOST=<your_api_host>
# POLYDATA_API_PORT=<your_api_port>
# POLYDATA_ALLOWED_ORIGINS=<comma_separated_allowed_origins>
# VITE_POLYDATA_API_BASE_URL=<your_frontend_api_base_url>
# POLYDATA_PUBLIC_WEB_URL=<your_frontend_web_url>

# ============================================================
# Redis / Snapshot
# ============================================================

# POLYDATA_REDIS_URL=<your_redis_url>
# POLYDATA_REDIS_PREFIX=<your_redis_prefix>
# POLYDATA_SNAPSHOT_SQLITE_PATH=<your_snapshot_sqlite_path>
# POLYDATA_SNAPSHOT_PREWARM=<enable_or_disable_snapshot_prewarm>

# ============================================================
# API 缓存 / Runtime TTL
# ============================================================

# POLYDATA_DASHBOARD_CACHE_TTL_SECONDS=<dashboard_cache_ttl_seconds>
# POLYDATA_MARKETS_CACHE_TTL_SECONDS=<markets_cache_ttl_seconds>
# POLYDATA_BOOTSTRAP_CACHE_TTL_SECONDS=<bootstrap_cache_ttl_seconds>
# POLYDATA_BOOTSTRAP_COMPONENT_TTL_SECONDS=<bootstrap_component_ttl_seconds>
# POLYDATA_DASHBOARD_TRADE_WINDOW=<dashboard_trade_window>
# POLYDATA_ADDRESS_CACHE_TTL_SECONDS=<address_cache_ttl_seconds>
# POLYDATA_CLOB_TIMEOUT_SECONDS=<clob_timeout_seconds>
# POLYDATA_CLOB_PRICE_CACHE_TTL_SECONDS=<clob_price_cache_ttl_seconds>
# POLYDATA_FINANCE_RUNTIME_TTL_SECONDS=<finance_runtime_ttl_seconds>
# POLYDATA_SPORTS_RUNTIME_TTL_SECONDS=<sports_runtime_ttl_seconds>
# POLYDATA_SIGNAL_RUNTIME_TTL_SECONDS=<signal_runtime_ttl_seconds>

# ============================================================
# 外部 API 来源
# ============================================================

# POLYDATA_CLOB_API_BASE=<your_clob_api_base_url>
# POLYDATA_CLOB_WS_URL=<your_clob_websocket_url>
# POLYDATA_GAMMA_API_BASE=<your_gamma_api_base_url>
# POLYDATA_POLYMARKET_DATA_API_BASE=<your_polymarket_data_api_base_url>
# POLYDATA_POLYMARKET_ACTIVITY_API_URL=<your_polymarket_activity_api_url>
# POLYDATA_YAHOO_CHART_BASE_URL=<your_market_chart_provider_url>
# POLYDATA_COINGECKO_BASE_URL=<your_crypto_provider_url>
# POLYDATA_ESPN_NBA_BASE_URL=<your_sports_news_provider_url>
# POLYDATA_ESPN_CORE_NBA_BASE_URL=<your_sports_predictor_provider_url>
# POLYDATA_NBA_LINEUPS_BASE_URL=<your_nba_lineups_provider_url>
# POLYDATA_NBA_OFFICIAL_BASE_URL=<your_nba_official_site_url>
# POLYDATA_CLEVELAND_FED_NOWCAST_URL=<your_macro_provider_url>
# POLYDATA_GEO_SHOCK_OFAC_SDN_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/SDN.XML
# POLYDATA_GEO_SHOCK_OFAC_CONSOLIDATED_URL=https://sanctionslistservice.ofac.treas.gov/api/PublicationPreview/exports/CONSOLIDATED.XML
# POLYDATA_GEO_SHOCK_FEDERAL_REGISTER_API_URL=https://www.federalregister.gov/api/v1/documents.json
# POLYDATA_GEO_SHOCK_CONFLICT_API_URL=<optional_conflict_feed_url>
# POLYDATA_GEO_SHOCK_SOURCE_URL=https://ofac.treasury.gov/sanctions-list-service
# POLYDATA_GEO_SHOCK_TTL_SECONDS=900
# POLYDATA_GEO_SHOCK_WATCH_INTERVAL_SECONDS=300
# POLYDATA_F1_BWENEWS_RSS_URL=<your_f1_or_sports_runtime_rss_url>
# POLYDATA_F1_BWENEWS_SOURCE_URL=<your_f1_or_sports_runtime_source_url>
# POLYDATA_JIN10_FLASH_API_URL=<your_jin10_flash_api_url>
# POLYDATA_JIN10_FLASH_DETAIL_BASE_URL=<your_jin10_flash_detail_base_url>
# POLYDATA_JIN10_LIVE_URL=<your_jin10_live_url>
# POLYDATA_RSS_BBC_WORLD_URL=<your_world_news_rss_url>
# POLYDATA_RSS_BBC_POLITICS_URL=<your_politics_news_rss_url>
# POLYDATA_RSS_COINDESK_URL=<your_crypto_news_rss_url>
# POLYDATA_RSS_ESPN_NEWS_URL=<your_sports_news_rss_url>
